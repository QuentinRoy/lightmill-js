{
  "name": "@lightmill/log-server",
  "version": "3.0.0-beta.34",
  "description": "Server, and middleware to receive, store and export lightmill logs",
  "author": "Quentin Roy <contact@quentinroy.fr>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "log-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "pnpm run generate-api-types && rm -rf dist && tsc -b tsconfig.build.json",
    "prepublish": "pnpm run build",
    "test": "cross-env NODE_ENV=test vitest --typecheck",
    "generate-api-types": "openapi-typescript node_modules/@lightmill/log-api/openapi.yaml --output ./generated/api.d.ts",
    "cli": "tsx ./src/cli.ts",
    "cli-watch": "tsx --watch ./src/cli.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/body-parser": "^1.19.5",
    "@types/cookie-session": "^2.0.48",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/yargs": "^17.0.32",
    "cross-env": "^7.0.3",
    "openapi-typescript": "^7.6.1",
    "string-dedent": "^3.0.1",
    "supertest": "^6.3.3",
    "tsx": "catalog:",
    "type-fest": "^4.9.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@lightmill/log-api": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "@standard-schema/spec": "npm:@jsr/standard-schema__spec@1.0.0-rc.0",
    "better-sqlite3": "^9.2.2",
    "change-case": "^5.4.1",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "csv": "^6.3.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "kysely": "^0.27.2",
    "loglevel": "^1.8.1",
    "remeda": "^1.36.0",
    "yargs": "17.7.2"
  },
  "engines": {
    "node": "^22.x.x"
  }
}
